{
  "name": "freespins-channel-bot",
  "version": "1.0.0",
  "description": "Discord bot that forwards links from Discord to Telegram with referral code replacement",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "daemon": "./start-bot.sh",
    "stop": "./stop-bot.sh",
    "status": "./status-bot.sh",
    "restart": "./stop-bot.sh && ./start-bot.sh",
    "test-all": "node testTelegram.js && node test.js && node testCatchup.js",
    "test-catchup": "node testCatchup.js",
    "catchup": "node runCatchup.js",
    "deploy": "node deploy-commands.js"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "discord.js": "^14.0.0",
    "dotenv": "^16.0.0",
    "pm2": "^6.0.14"
  },
  "keywords": [
    "discord",
    "telegram",
    "bot",
    "casino",
    "freespins"
  ],
  "author": "jmenichole",
  "license": "MIT"
}
