# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
ANNOUNCE_CHANNEL=announce_channel_id
MOD_CHANNEL=mod_channel_id

# Discord to Telegram Forwarding
MONITORED_CHANNEL_ID=channel_id_to_monitor_for_links
TELEGRAM_CHAT_ID=telegram_chat_id_to_send_messages_to

# Telegram Bot
# Do NOT commit your real token. Put it in your local .env only.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Use webhook mode instead of long-polling (requires a public URL)
# TELEGRAM_WEBHOOK_URL=https://your-domain.example.com/telegram/webhook